# =============================================================================
# AMORIA 9.9 (existing)
# =============================================================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
TELEGRAM_TOKEN=your_telegram_bot_token_here
ADMIN_ID=123456789

# =============================================================================
# ANORA 9.9 (new)
# =============================================================================
# Emotional Engine
ANORA_EMOTIONAL_ENGINE_ENABLED=true
ANORA_EMOTIONAL_DECAY_RATE=0.5
ANORA_EMOTIONAL_GROWTH_RATE=5.0

# Decision Engine
ANORA_DECISION_ENGINE_ENABLED=true
ANORA_RANDOM_WEIGHT=0

# Relationship Phases
ANORA_RELATIONSHIP_PHASES_ENABLED=true
ANORA_PHASE_THRESHOLDS={"stranger":3,"friend":6,"close":8,"romantic":10,"intimate":12}

# Conflict Engine
ANORA_CONFLICT_ENGINE_ENABLED=true
ANORA_JEALOUSY_DECAY_RATE=8.0
ANORA_DISAPPOINTMENT_DECAY_RATE=25.0

# Background Worker
ANORA_WORKER_ENABLED=true
ANORA_RINDU_GROWTH_INTERVAL=1800
ANORA_CONFLICT_DECAY_INTERVAL=1800
ANORA_SAVE_STATE_INTERVAL=60
ANORA_PROACTIVE_INTERVAL=300
ANORA_AUTO_BACKUP_INTERVAL=21600

# Role Settings
ANORA_ROLES_ENABLED=true
ANORA_ROLES_LIST=ipar,teman_kantor,pelakor,istri_orang

# Vulgar & Language
ANORA_VULGAR_WORDS_ENABLED=true
ANORA_VULGAR_INTENSITY=1.0
ANORA_MIXED_LANGUAGE_ENABLED=true
ANORA_SLANG_WORDS_ENABLED=true

# Database
ANORA_DB_PATH=data/anora99.db
